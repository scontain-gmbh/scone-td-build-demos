[36.602259, "o", "\u001b[1m\u001b[92m    Creating\u001b[0m binary (application) `hello-world` package\r\n\u001b[1m\u001b[91merror\u001b[0m: destination `/home/ubuntu/GIT/scone-td-build-demos/hello-world/hello-world` already exists\r\n\r\nUse `cargo init` to initialize the directory\r\n"]
[36.603756, "o", "Hello World already exists - using existing one\r\n"]
[37.207751, "o", "\u001b[38;5;141m\r\nWe compile the application within a Rust image:\r\n\r\n\u001b[0m"]
