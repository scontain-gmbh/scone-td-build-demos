[290.535559, "o", "\r\n            },\r\n        ],\r\n        secrets: [],\r\n        images: [\r\n            ImageDescription {\r\n                name: \"image-web-server\",\r\n                injection_files: [\r\n                    File {\r\n                        path: \"/config/player_initial_lives\",\r\n                        content: \"$$SCONE::game-demo-player_initial_lives$$\",\r\n                    },\r\n                    File {\r\n                        path: \"/config/ui_properties_file_name\",\r\n                        content: \"$$SCONE::game-demo-ui_properties_file_name$$\",\r\n                    },\r\n                    File {\r\n                        path: \"/config/game.properties\",\r\n                        content: \"$$SCONE::game-demo-game.properties$$\",\r\n                    },\r\n                    File {\r\n                        path: \"/config/user-interface.properties\",\r\n                        content: \"$$SCONE::game-demo-user-interface.properties$$\",\r\n                    },\r\n                ],\r\n            },\r\n        ],\r\n    }\r\n"]
